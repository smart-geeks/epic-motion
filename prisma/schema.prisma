// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Rol {
  ADMIN
  MAESTRO
  PADRE
  RECEPCIONISTA
}

enum EstatusAlumna {
  ACTIVA
  INACTIVA
  PRUEBA
}

enum EstiloClase {
  BALLET
  HIPHOP
  TAP
  JAZZ
  ACRO
}

enum EstadoSesion {
  PROGRAMADA
  INICIADA
  COMPLETADA
  NO_INICIADA
}

enum EstadoAsistencia {
  PRESENTE
  TARDE
  AUSENTE
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  VENCIDO
}

enum TipoPago {
  MENSUALIDAD
  CLASE_PRIVADA
  INSCRIPCION
  OTRO
}

enum TipoConcepto {
  MENSUALIDAD
  INSCRIPCION
  UNIFORME
  ENSAYO_SOLO
  CLASE_PRIVADA
  OTRO
}

enum EstadoCargo {
  PENDIENTE
  PAGADO
  VENCIDO
  CANCELADO
}

enum TipoEvento {
  RECITAL
  COMPETENCIA_INTERNA
  COMPETENCIA_EXTERNA
  SHOWCASE
  ENSAYO
}

enum TipoNota {
  RUTINARIA
  EXTRAORDINARIA
}

enum EstadoNota {
  BORRADOR
  APROBADA
  PUBLICADA
}

enum EstadoClasePrivada {
  AGENDADA
  PAGADA
  COMPLETADA
  CANCELADA
}

enum MotivoUniforme {
  SIN_PLAYERA
  SIN_ZAPATILLAS
  PEINADO_INCORRECTO
  OTRO
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA
}

enum CategoriaGrupo {
  EPIC_TOTZ
  HAPPY_FEET
  EPIC_ONE
  TEEN
  COMPETICION
}

enum TipoCursoEspecial {
  VACACIONES   // Campus o taller en períodos de vacaciones escolares
  CURSO_VERANO // Programa intensivo de verano (Julio–Agosto)
}

enum TipoTierGrupo {
  BASE  // EPIC TOTZ (paquete único sin selección)
  T1    // 1 clase/disciplina
  T2    // 2 clases/disciplinas
  T3    // 3 clases/disciplinas
  T4    // 4 clases/disciplinas
  FULL  // máximo disponible para la categoría
}

// ─────────────────────────────────────────────
// Modelos
// ─────────────────────────────────────────────

model Usuario {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique
  password  String
  nombre    String
  apellido  String
  telefono  String?
  rol       Rol
  avatar    String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Datos adicionales del tutor (capturados en el wizard)
  telefonoTrabajo        String?
  nombreConyuge          String?  // nombre del otro tutor
  celularConyuge         String?
  emailConyuge           String?
  telefonoTrabajoConyuge String?
  domicilio              String?

  // Relaciones
  alumnas              Alumna[]         @relation("PadreAlumnas")
  profesor             Profesor?
  noticiasAutor        Noticia[]        @relation("AutorNoticias")
  notificaciones       Notificacion[]
  lecturasNoticias     LecturaNoticia[] @relation("PadreLectura")
  pagosComoPadre       Pago[]           @relation("PadrePagos")
  cargosComoPadre      Cargo[]          @relation("PadreCargos")
  sesionesComoProfesor Sesion[]         @relation("ProfesorSesiones")
  clasesComoProfesor   Clase[]          @relation("ProfesorClases")
  notasComoMaestro     Nota[]           @relation("MaestroNotas")
  notasAprobadas       Nota[]           @relation("AdminAprobadorNotas")
  gruposComoProfesor   Grupo[]          @relation("ProfesorGrupos")
  cursosEspeciales     CursoEspecial[]  @relation("ProfesorCursosEspeciales")
}

model Alumna {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre           String
  apellido         String
  fechaNacimiento  DateTime
  foto             String?
  estatus          EstatusAlumna @default(ACTIVA)
  fechaInscripcion DateTime      @default(now())

  // Datos del expediente (capturados en el wizard de inscripción)
  institucionEducativa String?
  otraAcademia         String?  // nombre de academia anterior; null si ninguna
  enfermedadLesion     String?  // descripción; null si ninguna
  canalContacto        String?  // "WHATSAPP" | "EMAIL" | "TELEFONO"
  diaCobro             Int?     // día del mes (1-31) en que el cron genera la mensualidad
  invitadaCompetencia  Boolean  @default(false) // marcador para invitar a competencia

  // Relación con padre
  padreId String  @db.Uuid
  padre   Usuario @relation("PadreAlumnas", fields: [padreId], references: [id])

  // Relaciones
  clases              AlumnaClase[]
  asistencias         Asistencia[]
  pagos               Pago[]
  cargos              Cargo[]
  notas               Nota[]
  logros              Logro[]
  clasesPrivadas      ClasePrivada[]
  disciplinasInscritas AlumnaDisciplina[]
  cursosEspeciales     InscripcionCursoEspecial[]
}

model Salon {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre      String
  descripcion String?
  capacidad   Int

  // Relaciones
  clases  Clase[]
  grupos  Grupo[]
}

// ─────────────────────────────────────────────
// Módulo de Inscripciones — Catálogo comercial
// ─────────────────────────────────────────────

// Disciplina: Ballet, Hip-Hop, Tap, Jazz, Acro…
model Disciplina {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre      String   @unique
  descripcion String?
  imagenUrl   String?  // URL de imagen para landing page (Supabase Storage o externa)
  color       String?  // hex para badges en UI, ej. "#F8BBD0"
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())

  grupos   GrupoDisciplina[]
  alumnas  AlumnaDisciplina[]
}

// Grupo: unidad comercial de inscripción (SENIOR FULL, TINY FULL, etc.)
// En el futuro contendrá una FK a Clase para la operación diaria.
model Grupo {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre          String         @unique
  categoria       CategoriaGrupo @default(COMPETICION)
  esCompetitivo   Boolean        @default(false)
  tier            TipoTierGrupo  @default(FULL)
  edadMin         Int
  edadMax         Int
  horasPorSemana  Decimal        @db.Decimal(4, 1)
  dias            String[]       // días principales del grupo ["L","M","X","J","V","S","D"]
  horaInicio      String         // "16:00"
  duracionMinutos Int            // duración de sesión estándar (referencia)
  cupo            Int
  activo          Boolean        @default(true)
  descripcion     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Promoción automática al 1 de julio: alumnas de este grupo pasan al siguiente
  idGrupoSiguiente String? @db.Uuid
  grupoSiguiente   Grupo?  @relation("GrupoPromocion", fields: [idGrupoSiguiente], references: [id])
  gruposAnteriores Grupo[] @relation("GrupoPromocion")

  salonId    String?  @db.Uuid
  salon      Salon?   @relation(fields: [salonId], references: [id])
  profesorId String?  @db.Uuid
  profesor   Usuario? @relation("ProfesorGrupos", fields: [profesorId], references: [id])

  disciplinas       AlumnaClase[]      // alumnas inscritas en este grupo
  tarifa            TarifaMensualidad?
  disciplinasGrupo  GrupoDisciplina[]
  cargos            Cargo[]            // cargos generados por el cron para este grupo
  alumnasDisciplinas AlumnaDisciplina[]
}

// Tabla pivot Grupo ↔ Disciplina
// Cada fila representa una disciplina específica dentro de un grupo, con su propio horario.
model GrupoDisciplina {
  grupoId      String     @db.Uuid
  grupo        Grupo      @relation(fields: [grupoId], references: [id])
  disciplinaId String     @db.Uuid
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id])

  // Horario de esta disciplina dentro del grupo (puede diferir del horario principal del grupo)
  dias            String[] @default([])  // ["L","X"] = Lunes y Miércoles
  horaInicio      String   @default("") // "17:00"
  duracionMinutos Int      @default(60)
  horaTexto       String   @default("") // "Lun y Mié 17:00–18:00" — para display en mini-ticket

  @@id([grupoId, disciplinaId])
}

// Tabla pivot Alumna ↔ Disciplina dentro de un Grupo
// Permite configurar qué disciplinas específicas toma cada alumna dentro del grupo,
// lo que determina su mensualidad proporcional.
model AlumnaDisciplina {
  alumnaId     String @db.Uuid
  disciplinaId String @db.Uuid
  grupoId      String @db.Uuid

  alumna     Alumna     @relation(fields: [alumnaId], references: [id])
  disciplina Disciplina @relation(fields: [disciplinaId], references: [id])
  grupo      Grupo      @relation(fields: [grupoId], references: [id])

  @@id([alumnaId, disciplinaId, grupoId])
}

// Tarifa editable por el admin: 1 tarifa por grupo
model TarifaMensualidad {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  precioMensualidad Decimal  @db.Decimal(10, 2)
  precioPreseason   Decimal? @db.Decimal(10, 2)
  horasPorSemana    Decimal  @db.Decimal(4, 1) // referencia display
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  grupoId String @unique @db.Uuid
  grupo   Grupo  @relation(fields: [grupoId], references: [id])
}

model Clase {
  id       String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre   String
  estilo   EstiloClase
  nivel    String?
  duracion Int         // minutos
  dias     String[]
  horario  String
  cupo     Int

  // Relaciones con Salon y Profesor
  salonId    String  @db.Uuid
  salon      Salon   @relation(fields: [salonId], references: [id])
  profesorId String  @db.Uuid
  profesor   Usuario @relation("ProfesorClases", fields: [profesorId], references: [id])

  // Relaciones
  alumnas  AlumnaClase[]
  sesiones Sesion[]
  eventos  EventoGrupo[]
}

model AlumnaClase {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fechaInscripcion DateTime @default(now())

  alumnaId String  @db.Uuid
  alumna   Alumna  @relation(fields: [alumnaId], references: [id])
  claseId  String? @db.Uuid          // nullable hasta que el grupo tenga Clase asignada
  clase    Clase?  @relation(fields: [claseId], references: [id])
  grupoId  String? @db.Uuid          // grupo comercial de inscripción
  grupo    Grupo?  @relation(fields: [grupoId], references: [id])

  @@unique([alumnaId, claseId])
}

model Sesion {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fecha      DateTime
  horaInicio DateTime
  horaFin    DateTime
  estado     EstadoSesion @default(PROGRAMADA)
  checkinAt  DateTime?

  claseId    String  @db.Uuid
  clase      Clase   @relation(fields: [claseId], references: [id])
  profesorId String  @db.Uuid
  profesor   Usuario @relation("ProfesorSesiones", fields: [profesorId], references: [id])

  // Relaciones
  asistencias Asistencia[]
}

model Asistencia {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estado         EstadoAsistencia
  uniforme                   Boolean           @default(true)
  motivosUniforme            MotivoUniforme[]
  observacionComportamiento  String?           @db.Text
  createdAt                  DateTime          @default(now())

  sesionId String @db.Uuid
  sesion   Sesion @relation(fields: [sesionId], references: [id])
  alumnaId String @db.Uuid
  alumna   Alumna @relation(fields: [alumnaId], references: [id])

  @@unique([sesionId, alumnaId])
}

model Pago {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  importe             Decimal    @db.Decimal(10, 2)
  concepto            String
  fechaVencimiento    DateTime
  fechaPago           DateTime?
  estado              EstadoPago @default(PENDIENTE)
  comprobanteUrl      String?
  tipo                TipoPago
  metodoPago          MetodoPago @default(EFECTIVO)
  // Idempotencia: Stripe Checkout Session ID o número de rastreo bancario.
  // El índice UNIQUE bloquea a nivel de BD cualquier intento de cobrar el mismo ticket dos veces.
  referenciaExternaId String?    @unique

  alumnaId String  @db.Uuid
  alumna   Alumna  @relation(fields: [alumnaId], references: [id])
  padreId  String  @db.Uuid
  padre    Usuario @relation("PadrePagos", fields: [padreId], references: [id])

  // Relaciones
  clasesPrivadas ClasePrivada[]   @relation("PrepagoClasePrivada")
  aplicaciones   AplicacionPago[]
}

model Profesor {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tarifaHora     Decimal  @db.Decimal(10, 2)
  especialidades String[]

  usuarioId String  @unique @db.Uuid
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  // Relaciones
  clasesPrivadas ClasePrivada[]
}

model Evento {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipo        TipoEvento
  titulo      String
  descripcion String?
  fecha       DateTime
  ubicacion   String?
  cupo        Int?
  activo      Boolean    @default(true)

  // Relaciones
  grupos EventoGrupo[]
}

model EventoGrupo {
  eventoId String @db.Uuid
  evento   Evento @relation(fields: [eventoId], references: [id])
  claseId  String @db.Uuid
  clase    Clase  @relation(fields: [claseId], references: [id])

  @@id([eventoId, claseId])
}

model Noticia {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo    String
  cuerpo    String
  imagenUrl String?
  fecha     DateTime @default(now())
  activa    Boolean  @default(true)

  autorId String  @db.Uuid
  autor   Usuario @relation("AutorNoticias", fields: [autorId], references: [id])

  // Relaciones
  lecturas LecturaNoticia[]
}

model LecturaNoticia {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fechaLectura DateTime @default(now())

  noticiaId String  @db.Uuid
  noticia   Noticia @relation(fields: [noticiaId], references: [id])
  padreId   String  @db.Uuid
  padre     Usuario @relation("PadreLectura", fields: [padreId], references: [id])

  @@unique([noticiaId, padreId])
}

model Nota {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipo        TipoNota
  contenido   String
  estado      EstadoNota @default(BORRADOR)
  fecha       DateTime   @default(now())
  aprobadaPor   String?  @db.Uuid
  adminAprobador Usuario? @relation("AdminAprobadorNotas", fields: [aprobadaPor], references: [id], onDelete: SetNull)

  alumnaId  String  @db.Uuid
  alumna    Alumna  @relation(fields: [alumnaId], references: [id])
  maestroId String  @db.Uuid
  maestro   Usuario @relation("MaestroNotas", fields: [maestroId], references: [id])
}

model Logro {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipo            String
  nombre          String
  descripcion     String
  icono           String?
  puntos          Int
  fechaDesbloqueo DateTime @default(now())

  alumnaId String @db.Uuid
  alumna   Alumna @relation(fields: [alumnaId], references: [id])
}

model Notificacion {
  id     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipo   String
  titulo String
  cuerpo String?
  leida  Boolean  @default(false)
  fecha  DateTime @default(now())

  usuarioId String  @db.Uuid
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
}

model Paquete {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre          String
  clasesPorSemana Int
  precio          Decimal  @db.Decimal(10, 2)
  estilosIncluidos String[]
  activo          Boolean  @default(true)
}

model ClasePrivada {
  id       String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fecha    DateTime
  hora     String
  duracion Int                @default(60)
  estado   EstadoClasePrivada @default(AGENDADA)

  alumnaId   String   @db.Uuid
  alumna     Alumna   @relation(fields: [alumnaId], references: [id])
  profesorId String   @db.Uuid
  profesor   Profesor @relation(fields: [profesorId], references: [id])
  prepagoId  String?  @db.Uuid
  prepago    Pago?    @relation("PrepagoClasePrivada", fields: [prepagoId], references: [id])
}

// ─────────────────────────────────────────────
// Motor de Cobros
// ─────────────────────────────────────────────

// Catálogo de productos y servicios que ofrece la academia.
// Define el precio base; el Cargo puede ajustarlo (descuentos, excepciones).
model Concepto {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre      String
  descripcion String?
  tipo        TipoConcepto
  precioSugerido Decimal     @db.Decimal(10, 2) // precio base sugerido
  activo      Boolean      @default(true)
  createdAt   DateTime     @default(now())

  // Relaciones
  cargos Cargo[]
}

// Libro mayor de cuentas por cobrar.
// Un Cargo nace PENDIENTE al inscribir a la alumna o al generar
// la mensualidad del mes, y pasa a PAGADO cuando se registra el Pago.
model Cargo {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // ── Lógica financiera ────────────────────────────────────────────────────────
  // montoFinal = montoOriginal - descuento
  // Se calculan y persisten al crear el Cargo para auditabilidad.
  montoOriginal    Decimal     @db.Decimal(10, 2) // precio base del Concepto al momento de generar el cargo
  descuento        Decimal     @db.Decimal(10, 2) @default(0) // monto a restar (0 = sin descuento)
  montoFinal       Decimal     @db.Decimal(10, 2) // lo que el padre debe realmente pagar
  motivoDescuento  String?     // ej. "familia numerosa", "beca parcial", "cortesía"
  // ── Fechas ───────────────────────────────────────────────────────────────────
  fechaVencimiento DateTime
  fechaPago        DateTime?   // se rellena al marcar PAGADO
  // ── Estado ───────────────────────────────────────────────────────────────────
  estado           EstadoCargo @default(PENDIENTE)
  notas            String?     // observaciones internas
  // ── Notificaciones WhatsApp ──────────────────────────────────────────────────
  // false → no enviada; true → ya enviada (manual o por n8n)
  notificado3Dias  Boolean     @default(false) // recordatorio 3 días antes del vencimiento
  notificadoHoy    Boolean     @default(false) // aviso el día del vencimiento
  // ── Timestamps ───────────────────────────────────────────────────────────────
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // Qué se está cobrando
  conceptoId String   @db.Uuid
  concepto   Concepto @relation(fields: [conceptoId], references: [id])

  // A quién se le cobra
  alumnaId String @db.Uuid
  alumna   Alumna @relation(fields: [alumnaId], references: [id])

  // Quién es el responsable de pago
  padreId String  @db.Uuid
  padre   Usuario @relation("PadreCargos", fields: [padreId], references: [id])

  // Grupo al que corresponde este cargo (trazabilidad + idempotencia del cron)
  grupoId String? @db.Uuid
  grupo   Grupo?  @relation(fields: [grupoId], references: [id])

  // Pagos que cubren (parcial o totalmente) este cargo
  aplicaciones AplicacionPago[]
}

// ─────────────────────────────────────────────
// Tabla pivote para pagos parciales
// ─────────────────────────────────────────────

// Registra cuánto de un Pago se aplicó a un Cargo específico.
// Permite pagos parciales (un Cargo cubierto por varios Pagos) y
// pagos en bloque (un Pago que cubre varios Cargos a la vez).
model AplicacionPago {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  montoAplicado  Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  cargoId String @db.Uuid
  cargo   Cargo  @relation(fields: [cargoId], references: [id])
  pagoId  String @db.Uuid
  pago    Pago   @relation(fields: [pagoId], references: [id])

  @@unique([cargoId, pagoId])
}

model Configuracion {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clave       String  @unique
  valor       String
  descripcion String?
}

// ─────────────────────────────────────────────
// Cursos Especiales: Vacaciones & Verano
// Tabla separada de Grupo — programas de tiempo limitado con fechas definidas.
// ─────────────────────────────────────────────

model CursoEspecial {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre          String            @unique
  tipo            TipoCursoEspecial
  descripcion     String?           // notas internas de operación
  fechaInicio     DateTime
  fechaFin        DateTime
  cupo            Int
  precio          Decimal           @db.Decimal(10, 2)
  activo          Boolean           @default(false) // false = inscripciones cerradas
  diasSemana      String[]          // ["L","M","X","J","V"]
  horaInicio      String            // "09:00"
  duracionMinutos Int               @default(60)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  profesorId String?  @db.Uuid
  profesor   Usuario? @relation("ProfesorCursosEspeciales", fields: [profesorId], references: [id])

  inscritas InscripcionCursoEspecial[]
}

// Tabla pivot Alumna ↔ CursoEspecial
model InscripcionCursoEspecial {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fechaInscripcion DateTime      @default(now())

  alumnaId String        @db.Uuid
  alumna   Alumna        @relation(fields: [alumnaId], references: [id])
  cursoId  String        @db.Uuid
  curso    CursoEspecial @relation(fields: [cursoId], references: [id])

  @@unique([alumnaId, cursoId])
}
