# ──────────────────────────────────────────────────────────
# Epic Motion App — Variables de entorno
# ──────────────────────────────────────────────────────────
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env a Git (ya está en .gitignore).
# ──────────────────────────────────────────────────────────

# ── Base de datos (Supabase PostgreSQL) ─────────────────
# Connection pooling (PgBouncer) — para la app en runtime
DATABASE_URL="postgresql://postgres.XXXX:PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexión directa — para migraciones de Prisma
DIRECT_URL="postgresql://postgres.XXXX:PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# ── NextAuth ────────────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="genera-un-secret-aleatorio-aqui"
NEXTAUTH_URL="http://localhost:3000"

# ── Supabase (opcional: solo si usas Storage para imágenes) ──
# NEXT_PUBLIC_SUPABASE_URL="https://XXXX.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIs..."

# ── Cron Jobs ───────────────────────────────────────────
# Token para autenticar el endpoint de generación de cargos
# Generar con: openssl rand -hex 32
# CRON_SECRET="tu-cron-secret-aqui"

# UUID del usuario Admin que ejecuta el cron (ej: luz@epicmotion.com)
# CRON_ADMIN_USER_ID="uuid-del-admin-aqui"
